TG_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrSTUvwxYZ
TG_CHAT_ID=-1001234567890
TG_TEST_CHAT_ID=-1009876543210

# Comma-separated API keys, format: label:key (label is optional)
# Use label "public" for key shown in TG "Дивитись онлайн" button
API_KEYS=admin:my-admin-key,vasyl:vasyl-key-abc123,public:public-key-for-dashboard

# Bot webhook: set to your public HTTPS URL to enable /status command in Telegram
WEBHOOK_HOST=https://your-domain.example.com

# Update channel avatar on service start (1=yes, 0=no)
AVATAR_ON_START=1

# Delete "Channel photo updated" service message (1=on, 0=off)
DELETE_PHOTO_MSG=0

# GitHub deploy webhook: secret for X-Hub-Signature-256. When set, POST /api/deploy-hook deploys on push.
# Repo → Settings → Webhooks → Add webhook → Payload URL, Secret, Events: push.
# Set AUTO_DEPLOY=0 to disable polling and use webhook only.
GITHUB_WEBHOOK_SECRET=

# Detection mode: 1 = use only Deye phases (L1/L2/L3), 0 = use smart plugs (plug204/plug175)
PHASES_ONLY=0

# alerts.in.ua: district-level alerts (Броварський район etc). Get token: https://alerts.in.ua/api-request
# When set, used instead of alerts.com.ua (oblast-level only)
ALERT_IN_UA_TOKEN=

# DTEK schedule: region slug and queue
# Defaults: Kyiv Oblast (DTEK KREM), queue 5.1
# Available regions: kiivska-oblast, kyiv, odeska-oblast, dnipro-dnem, etc.
DTEK_REGION=kiivska-oblast
DTEK_QUEUE=5.1

# Deye inverter: battery capacity in kWh (for energy stats: consumed/remaining kWh, time to empty). 0 = disabled
DEYE_BATTERY_KWH=

# Server-side Deye polling (when set, GCP polls Deye directly via port forward; no local script needed)
# See docs/DEYE_PORT_FORWARD.md for MikroTik NAT + firewall setup
DEYE_POLL_IP=
DEYE_POLL_PORT=18899
DEYE_POLL_SERIAL=
DEYE_POLL_INTERVAL_SEC=30
# DEYE_POLL_LOG=logs/deye_poll.log  # optional, default: power-monitor/logs/deye_poll.log
